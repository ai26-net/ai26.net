---
import IndexBase from "@src/layouts/Base.astro";
import config from "@src/config";
import { User, Zap, Info, MoveUpRight, Eclipse, MessageCircle } from "lucide-react";

const iconMap: Record<string, any> = {
  User,
  Zap,
  Info,
  MessageCircle,
};

const { icons } = config.home;
---

<IndexBase>
  <nav class="w-full flex items-center justify-start py-4 border-b border-gray-200 px-4">
    <div class="flex items-center gap-2 font-bold text-base">
      <Eclipse size={24} class="text-gray-800" />
      <span>AI26</span>
    </div>
  </nav>

  <div class="w-full mx-auto py-8 px-4 md:px-8 lg:w-8/12 xl:w-8/12">
    <div class="flex gap-4">
      {icons.map((item: { label: string; href: string; icon: string; color: string }) => {
        const IconComponent = iconMap[item.icon];
        return (
          <a href={item.href} target={item.href.startsWith("http") ? "_blank" : "_self"} class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-gray-100 transition-colors cursor-pointer w-28">
            <div class={`w-20 h-20 rounded-lg flex items-center justify-center ${item.color}`}>
              {IconComponent && <IconComponent size={36} />}
            </div>
            <span class="text-xs font-medium">{item.label}</span>
          </a>
        );
      })}
    </div>
  </div>
</IndexBase>
